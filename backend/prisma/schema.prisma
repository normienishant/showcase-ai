generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  primaryColor   String?
  logoUrl        String?
  whatsappNumber String?
  websiteUrl     String?
  createdAt      DateTime   @default(now())
  admins         Admin[]
  categories     Category[]
  leads          Lead[]
  products       Product[]
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  companyId String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  companyId String
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  company   Company    @relation(fields: [companyId], references: [id])
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  specs       Json?
  images      Json?
  documents   Json?
  isVisible   Boolean  @default(true)
  categoryId  String
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])
}

model Lead {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  message          String?
  wishlistSnapshot Json?
  status           String   @default("new")
  companyId        String
  visitorId        String?
  createdAt        DateTime @default(now())
  company          Company  @relation(fields: [companyId], references: [id])
}

model VisitorSession {
  id           String         @id @default(cuid())
  visitorId    String
  sessionId    String         @unique
  startedAt    DateTime       @default(now())
  lastActivity DateTime       @default(now())
  ipAddress    String?
  userAgent    String?
  referrer     String?
  events       VisitorEvent[]
}

model VisitorEvent {
  id         String         @id @default(cuid())
  visitorId  String
  sessionId  String
  eventType  String
  productId  String?
  categoryId String?
  eventData  Json?
  createdAt  DateTime       @default(now())
  session    VisitorSession @relation(fields: [sessionId], references: [sessionId])
}

model IntentScore {
  id          String   @id @default(cuid())
  visitorId   String   @unique
  score       Int      @default(0)
  lastUpdated DateTime @default(now())
  categoryId  String?
  productId   String?
}

model ProcurementSession {
  id            String   @id @default(cuid())
  fileName      String
  fileUrl       String
  status        String   @default("uploaded")
  extractedData Json?
  boqData       Json?
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
